<%
  var targetPost = null;
  var label = '';
  var slug = page.slug || '';

  if (slug.endsWith('-en')) {
    var cnSlug = slug.replace(/-en$/, '');
    targetPost = site.posts.find({ slug: cnSlug }).first();
    if (targetPost) {
      label = '📖 本文也有<a href="' + url_for(targetPost.path) + '" style="color: #1a73e8; font-weight: 600;">中文版本</a>';
    }
  } else {
    var enSlug = slug + '-en';
    targetPost = site.posts.find({ slug: enSlug }).first();
    if (targetPost) {
      label = '📖 This article is also available in <a href="' + url_for(targetPost.path) + '" style="color: #1a73e8; font-weight: 600;">English</a>';
    }
  }

  if (targetPost) {
%>
<div style="margin-bottom: 1.5rem; padding: 0.75rem 1rem; background: #f0f7ff; border-left: 4px solid #4a9eff; border-radius: 4px; font-size: 0.95rem;">
  <%- label %>
</div>
<% } %>
